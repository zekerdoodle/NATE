# OpenAI API Key for LLM functionality
OPENAI_API_KEY=sk-your-openai-api-key-here

# NinjaOne API Credentials
# Get these from your NinjaOne admin portal under Administration > Apps > API
NinjaOne_ClientID=your-client-id-here
NinjaOne_ClientSecret=your-client-secret-here
NinjaOne_BaseURL=https://your-instance.ninjarmm.com/

# NinjaOne OAuth Refresh Token (obtained via setup_auth.py script)
NINJA_REFRESH_TOKEN=your-refresh-token-here
